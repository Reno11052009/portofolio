# SMTP Configuration (Nodemailer)
# Replace these with your actual SMTP credentials.
# For Gmail, configure SMTP_HOST=smtp.gmail.com and SMTP_PORT=587, and use an App Password.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password-here
# get the app password here https://myaccount.google.com/apppasswords

# The email address that will receive the contact form submissions
CONTACT_RECEIVER_EMAIL=your-email-@example.com
